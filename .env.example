# ─────────────────────────────────────────────────────────────
#  GPURental Server - 設定ファイルテンプレート
#  ① このファイルをコピーして「.env」という名前で保存してください
#     コマンド例: copy .env.example .env
#  ② 必要な項目を編集してください（★ 必須  ☆ 任意）
# ─────────────────────────────────────────────────────────────

# ─── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Storage (★ 必須: データ保存先フォルダ) ──────────────────
# ZIPをCドライブ直下に展開した場合はそのまま使えます（変更不要）
# ※ バックスラッシュ(\)ではなくスラッシュ(/)で記載してください
STORAGE_PATH=C:/gpu-rental-main/data
DB_PATH=C:/gpu-rental-main/data/db/platform.db

# ─── JWT Secret (★ 必須: 変更してください) ───────────────────
# 任意の長い文字列（例: パスワードマネージャーで生成したランダム文字列）
JWT_SECRET=change-this-to-a-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=8h

# ─── Admin Account (★ 必須: 管理者ログイン情報) ──────────────
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=YourStrongPassword123

# ─── GPU Monitor ─────────────────────────────────────────────
GPU_POLL_INTERVAL=5000
TEMP_ALERT_THRESHOLD=85

# ─── Provider Payout Rate ────────────────────────────────────
PROVIDER_PAYOUT_RATE=0.8

# ─── Upload Limits ───────────────────────────────────────────
MAX_UPLOAD_SIZE_GB=10

# ─── Base URL (☆ 任意: 公開URLがある場合) ────────────────────
# ローカルのみで使う場合はそのままでOK
BASE_URL=http://localhost:3000

# ─── Email / SMTP (☆ 任意: メール通知を使う場合) ─────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ─── Cloudflare Tunnel (☆ 任意: 外部公開する場合) ────────────
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ─── Stripe (☆ 任意: 決済機能を使う場合) ─────────────────────
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PLATFORM_FEE_RATE=0.10

# ─── reCAPTCHA (☆ 任意) ──────────────────────────────────────
# RECAPTCHA_SITE_KEY=your_site_key_here
# RECAPTCHA_SECRET_KEY=your_secret_key_here
