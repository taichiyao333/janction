{
  "name": "janction-agent",
  "version": "1.0.0",
  "description": "Janction Provider Agent - ワンクリックGPU公開ツール",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "pkg src/index.js --targets node20-win-x64 --output dist/janction-agent.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "assets/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "open": "^9.1.0",
    "playwright-core": "^1.58.2",
    "socket.io-client": "^4.7.2"
  }
}
